# 1. Create solution and project
dotnet new sln -n PaymentServices.Shared
mkdir src
cd src
dotnet new classlib -n PaymentServices.Shared -f net10.0
cd ..
dotnet sln add src/PaymentServices.Shared.csproj

# 2. Remove default Class1.cs
rm src/Class1.cs

# 3. Create folder structure
mkdir -p src/Enums
mkdir -p src/Messages
mkdir -p src/Models
mkdir -p src/Interfaces
mkdir -p src/Infrastructure
mkdir -p src/Extensions
mkdir -p pipelines

# 4. Add NuGet packages
cd src
dotnet add package Microsoft.Azure.Cosmos --version 3.46.0
dotnet add package Azure.Messaging.ServiceBus --version 7.18.4
dotnet add package Azure.Identity --version 1.13.2
dotnet add package System.Text.Json --version 9.0.4
dotnet add package Microsoft.Extensions.Logging.Abstractions --version 10.0.0
dotnet add package Microsoft.Extensions.DependencyInjection.Abstractions --version 10.0.0
dotnet add package Microsoft.Extensions.Options --version 10.0.0
cd ..

# 5. Verify restore
cd src
dotnet restore
dotnet build


